POSTGRES_DB=ecommerce_ml
POSTGRES_USER=ml_user
POSTGRES_PASSWORD=ml_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=ecommerce-transactions

SOURCE_CSV=/app/data/raw/ecommerce_sample.csv
RAW_LAKE_DIR=/app/data/raw/kafka_ingested
PROCESSED_DIR=/app/data/processed

API_HOST=0.0.0.0
API_PORT=8000

# Optional. When set, lake-writer also attempts to upload raw files via WebHDFS.
HDFS_NAMENODE_WEBHDFS_URL=http://namenode:9870
HDFS_RAW_DIR=/data/ecommerce/raw

